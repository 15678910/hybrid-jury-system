{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "siminbupjung-blog",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/blog/**",
        "function": "blog"
      },
      {
        "source": "/v/**",
        "function": "videos"
      },
      {
        "source": "/sentencing-analysis",
        "function": "sentencingAnalysisPage"
      },
      {
        "source": "/reform-analysis",
        "function": "reformAnalysisPage"
      },
      {
        "source": "/trial-analysis",
        "function": "trialAnalysisPage"
      },
      {
        "source": "/judge-evaluation",
        "function": "judgeEvaluationPage"
      },
      {
        "source": "/judge/**",
        "function": "judgeDetailPage"
      },
      {
        "source": "/governance",
        "function": "governancePage"
      },
      {
        "source": "/europe-jury",
        "function": "europeJuryPage"
      },
      {
        "source": "/case-search",
        "function": "caseSearchPage"
      },
      {
        "source": "/donate",
        "function": "donatePage"
      },
      {
        "source": "/judicial-network",
        "function": "judicialNetworkPage"
      },
      {
        "source": "/law-database",
        "function": "lawDatabasePage"
      },
      {
        "source": "/chat",
        "function": "chatPage"
      },
      {
        "source": "/news",
        "function": "newsPage"
      },
      {
        "source": "/simulation",
        "function": "simulationPage"
      },
      {
        "source": "/precedent/**",
        "function": "precedentDetailPage"
      },
      {
        "source": "/jury-academy",
        "function": "juryAcademyPage"
      },
      {
        "source": "/mock-trial",
        "function": "mockTrialPage"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|eot)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "maxInstances": 10
  }
}
