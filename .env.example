# ============================================================
# .env.example — copy to .env.local for local development
# NEVER commit .env.local or .env to version control
# ============================================================

# Kakao JavaScript SDK key (browser-restricted by domain on Kakao Developers Console)
# Register app at https://developers.kakao.com → 앱 키 → JavaScript 키
# Then add domain restriction: 플랫폼 → Web → 사이트 도메인 등록
VITE_KAKAO_KEY=your-kakao-javascript-key-here

# Google OAuth Client ID (Firebase Console → Authentication → Google → 웹 클라이언트 ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Admin Passwords
VITE_ADMIN_PASSWORD=your-admin-password-here
VITE_ADMIN_CODE=your-admin-code-here
VITE_WRITER_CODE=your-writer-code-here

# reCAPTCHA v3 Site Key (Firebase App Check)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here

# Google Gemini API (server-side, not exposed to browser)
GOOGLE_API_KEY=your-gemini-api-key-here

# ============================================================
# Firebase Functions (server-side) — set via CLI, not .env
# ============================================================
# firebase functions:config:set kakao.app_key="<your-kakao-js-key>"
# firebase deploy --only functions
#
# NOTE: Server-side (Cloud Functions) usage bypasses Kakao domain restriction.
# Consider migrating to REST API key for backend calls in a future milestone.
# ============================================================
